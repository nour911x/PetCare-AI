# Copie ce fichier en .env et remplis tes vraies clés API
# Le fichier .env ne doit JAMAIS être commité (il est dans .gitignore)

# Choix du fournisseur LLM : "groq" (gratuit, rapide) ou "openai" (payant)
LLM_PROVIDER=groq

# Clé Groq (gratuite sur https://console.groq.com)
GROQ_API_KEY=ta_cle_groq_ici

# Clé OpenAI (optionnelle, payante)
OPENAI_API_KEY=ta_cle_openai_ici

# Modèle d'embeddings (local, gratuit, pas besoin de clé)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
